{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "tags": ["knowledge-search"],
  "title": "Поисковая система — мониторинг",
  "uid": "knowledge-search",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Всего запросов к /search",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "expr": "sum(http_request_duration_seconds_count{handler=\"/api/v1/search\"})",
          "legendFormat": "запросов",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Среднее время ответа /search (мс)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1 } },
      "targets": [
        {
          "expr": "1000 * sum(rate(http_request_duration_seconds_sum{handler=\"/api/v1/search\"}[5m])) / sum(rate(http_request_duration_seconds_count{handler=\"/api/v1/search\"}[5m]))",
          "legendFormat": "среднее",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Запросы к /search (в секунду)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{handler=\"/api/v1/search\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Среднее время ответа по эндпоинтам",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_sum[5m])) / sum by (handler) (rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Запросы по эндпоинтам и статусам (в секунду)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (handler, status) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{handler}} ({{status}})",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  }
}
